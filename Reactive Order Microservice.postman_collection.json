      "name": "auth-service",
      "item": [
        {
          "name": "auth",
          "item": [
            {
              "name": "Login",
              "event": [
                {
                  "listen": "prerequest",
                  "script": {
                    "exec": [
                      ""
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                },
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Check if response status is successful\r",
                      "if (pm.response.code === 200) {\r",
                      "    // Parse the response\r",
                      "    const response = pm.response.json();\r",
                      "    \r",
                      "    // Check if tokens exist in response\r",
                      "    if (response.access_token && response.refresh_token) {\r",
                      "        // Save tokens to environment variables\r",
                      "        pm.environment.set(\"access_token\", response.access_token);\r",
                      "        pm.environment.set(\"refresh_token\", response.refresh_token);\r",
                      "        pm.environment.set(\"token_type\", response.token_type || \"Bearer\");\r",
                      "        \r",
                      "        \r",
                      "        console.log(\"✅ Tokens saved successfully!\");\r",
                      "        console.log(\"Access Token:\", response.access_token.substring(0, 20) + \"...\");\r",
                      "        console.log(\"Refresh Token:\", response.refresh_token.substring(0, 20) + \"...\");\r",
                      "    } else {\r",
                      "        console.error(\"❌ Tokens not found in response\");\r",
                      "        console.log(\"Response structure:\", Object.keys(response));\r",
                      "    }\r",
                      "} else {\r",
                      "    console.error(\"❌ Login failed with status:\", pm.response.code);\r",
                      "    console.error(\"Error:\", pm.response.text());\r",
                      "}"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\r\n    \"email\" : \"syamsandi@mail.com\",\r\n    \"password\" : \"Syamsandi_1!\"\r\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "{{base_url}}:8080/api/v1/auth/login",
                  "host": [
                    "{{base_url}}"
                  ],
                  "port": "8080",
                  "path": [
                    "api",
                    "v1",
                    "auth",
                    "login"
                  ]
                }
              },
              "response": []
            },
