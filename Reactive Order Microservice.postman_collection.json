                      "    \r",
                      "        \r",
                      "        console.log(\"✅ Tokens saved successfully!\");\r",
                      "        console.log(\"Access Token:\", response.access_token.substring(0, 20) + \"...\");\r",
                      "        console.log(\"Refresh Token:\", response.refresh_token.substring(0, 20) + \"...\");\r",
                      "    } else {\r",
                      "        console.error(\"❌ Tokens not found in response\");\r",
                      "        console.log(\"Response structure:\", Object.keys(response));\r",
                      "    }\r",
                      "} else {\r",
                      "    console.error(\"❌ Login failed with status:\", pm.response.code);\r",
                      "    console.error(\"Error:\", pm.response.text());\r",
                      "}"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
